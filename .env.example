# DeepAgents Environment Configuration Example

# API Keys (required for various agents)
TAVILY_API_KEY=your_tavily_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith Configuration (optional, for tracing)
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=your_project_name_here
LANGCHAIN_TRACING_V2=true

# NOTE: USE_V1_CORE is OBSOLETE. The v0 code path was removed — the current graph.py is
# unconditionally LangChain v1 (create_agent + middleware). This flag no longer has any effect
# and is kept only so old .env files don't error. (Superseded repo — see README banner.)
# USE_V1_CORE=true

# Model Configuration (optional)
# Historical: this first-gen repo hardcoded Claude Sonnet 4-era models. For current model
# selection (local Ollama / llama.cpp / Ollama Cloud frontier), see the successor:
# https://github.com/FinnMacCumail/ollamaDeepAgents
# DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514